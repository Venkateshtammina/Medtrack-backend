{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/health",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "status": 200,
      "dest": "server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/jobs/expiry-alerts",
      "schedule": "16 8 * * *"
    }
  ]
}
